{
  "name": "@raviolelabs/engram-mcp",
  "version": "0.5.8",
  "mcpName": "io.github.RavioleLabs/engram-mcp",
  "description": "EngramMCP — local-first semantic memory layer for AI agents",
  "license": "Elastic-2.0",
  "type": "module",
  "bin": {
    "engram-mcp": "dist/scripts/serve.js",
    "engram-mcp-install": "dist/scripts/install.js",
    "engram-mcp-pair": "dist/scripts/pair.js",
    "engram-mcp-rebuild": "dist/scripts/rebuild.js",
    "engram-mcp-service": "dist/scripts/service.js"
  },
  "scripts": {
    "dev": "tsx watch src/scripts/serve.ts",
    "reindex": "tsx src/scripts/reindex.ts",
    "install:wizard": "tsx src/scripts/install.ts",
    "pair": "tsx src/scripts/pair.ts",
    "rebuild": "tsx src/scripts/rebuild.ts",
    "build": "tsc && chmod +x dist/scripts/serve.js dist/scripts/install.js dist/scripts/pair.js dist/scripts/rebuild.js dist/scripts/service.js",
    "pack-binary": "tsx scripts/pack-binary.ts",
    "start": "node dist/scripts/serve.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "dev:client": "vite --config src/client/vite.config.ts",
    "build:client": "vite build --config src/client/vite.config.ts",
    "build:all": "npm run build:client && npm run build"
  },
  "dependencies": {
    "@lancedb/lancedb": "0.27.1",
    "@modelcontextprotocol/sdk": "1.28.0",
    "@notionhq/client": "2.3.0",
    "@tanstack/react-query": "5.100.14",
    "@types/multer": "2.1.0",
    "better-sqlite3": "12.8.0",
    "cytoscape": "3.33.3",
    "cytoscape-fcose": "2.2.0",
    "express": "5.2.1",
    "fast-xml-parser": "5.8.0",
    "googleapis": "172.0.0",
    "libsodium-wrappers": "0.8.4",
    "multer": "2.1.1",
    "node-cron": "4.2.1",
    "nodejs-whisper": "0.2.4",
    "pdf-parse": "2.4.5",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-router-dom": "7.12.0",
    "secrets.js-grempe": "2.0.0",
    "ulid": "2.4.0",
    "undici": "8.3.0",
    "ws": "8.21.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/cytoscape": "3.21.9",
    "@types/express": "5.0.0",
    "@types/libsodium-wrappers": "0.7.14",
    "@types/node": "22.19.19",
    "@types/node-cron": "3.0.11",
    "@types/pdf-parse": "1.1.5",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@types/ws": "8.5.0",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "@vitejs/plugin-react": "6.0.2",
    "@yao-pkg/pkg": "6.19.0",
    "autoprefixer": "10.4.0",
    "eslint": "9.0.0",
    "postcss": "8.5.15",
    "prettier": "3.0.0",
    "tailwindcss": "4.0.0",
    "tsx": "4.22.3",
    "typescript": "5.7.3",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "@yao-pkg/pkg": {
      "minimatch": "9.0.7"
    }
  },
  "files": [
    "dist/",
    "src/private/README.md",
    "README.md",
    "SKILL.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "pkg": {
    "assets": [
      "dist/**/*.json",
      "dist/**/*.node"
    ],
    "scripts": [
      "dist/**/*.js"
    ]
  },
  "homepage": "https://engram-mcp.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RavioleLabs/engram-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/RavioleLabs/engram-mcp/issues"
  },
  "keywords": [
    "mcp",
    "memory",
    "semantic-search",
    "embeddings",
    "local-first",
    "rag",
    "ai-agents",
    "claude",
    "cursor"
  ],
  "author": "RavioleLabs <hello@raviolelabs.com> (https://raviolelabs.com)"
}
